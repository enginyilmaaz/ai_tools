{
  "name": "ai-tool",
  "version": "2.0.0",
  "description": "AI Tool",
  "author": "enginyilmaaz",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron . --no-sandbox",
    "dev": "electronmon . --no-sandbox",
    "alive": "electronmon . --no-sandbox",
    "build:win": "node ./node_modules/electron-builder/cli.js --win nsis portable",
    "build:win:portable": "node ./node_modules/electron-builder/cli.js --win portable",
    "build:linux": "node ./node_modules/electron-builder/cli.js --linux deb",
    "build:standalone": "node ./node_modules/electron-builder/cli.js --linux AppImage",
    "set-scripts": "node set-features.js"
  },
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "electronmon": "^2.0.3"
  },
  "build": {
    "appId": "com.enginyilmaaz.aitool",
    "productName": "AI Tool",
    "directories": {
      "output": "out"
    },
    "files": [
      "src/**/*"
    ],
    "asar": true,
    "win": {
      "icon": "src/renderer/assets/app.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "artifactName": "${productName} Setup ${version}.${ext}",
      "shortcutName": "AI Tool",
      "installerIcon": "src/renderer/assets/app.ico",
      "uninstallerIcon": "src/renderer/assets/app.ico"
    },
    "linux": {
      "executableName": "ai-tool",
      "icon": "src/renderer/assets/app.png",
      "executableArgs": [
        "--no-sandbox"
      ],
      "target": [
        {
          "target": "deb",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "AppImage",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "Development",
      "maintainer": "enginyilmaaz",
      "desktop": {
        "StartupWMClass": "ai-tool"
      }
    },
    "deb": {
      "depends": [
        "libgtk-3-0",
        "libnotify4",
        "libnss3",
        "libxss1",
        "libxtst6",
        "xdg-utils",
        "libatspi2.0-0",
        "libuuid1",
        "libsecret-1-0"
      ]
    }
  },
  "dependencies": {
    "pg": "^8.20.0"
  }
}
